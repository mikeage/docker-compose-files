{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"extends": [
		"config:best-practices",
		"docker:enableMajor"
	],
	"labels": [
		"dependencies"
	],
	"lockFileMaintenance": {
		"automerge": true
	},
	"packageRules": [
		{
			"description": "Label GitHub Actions updates clearly.",
			"matchManagers": [
				"github-actions"
			],
			"addLabels": [
				"github-actions"
			]
		},
		{
			"description": "Label Docker updates clearly.",
			"matchDatasources": [
				"docker"
			],
			"addLabels": [
				"docker"
			]
		},
		{
			"description": "Label digest updates clearly.",
			"matchUpdateTypes": [
				"digest",
				"pinDigest"
			],
			"addLabels": [
				"digest"
			]
		},
		{
			"description": "Automerge digest updates and pins.",
			"matchUpdateTypes": [
				"digest",
				"pinDigest"
			],
			"automerge": true
		},
		{
			"description": "Require manual approval for risky Docker major updates.",
			"matchDatasources": [
				"docker"
			],
			"matchPackageNames": [
				"apache/tika",
				"docker.io/apache/tika",
				"docker.io/gotenberg/gotenberg",
				"docker.io/library/mariadb",
				"docker.io/library/postgres",
				"docker.io/library/redis",
				"docker.io/valkey/valkey",
				"getmeili/meilisearch",
				"ghcr.io/immich-app/postgres",
				"gotenberg/gotenberg",
				"mariadb",
				"postgres",
				"redis",
				"valkey/valkey"
			],
			"matchUpdateTypes": [
				"major"
			],
			"dependencyDashboardApproval": true
		}
	]
}
